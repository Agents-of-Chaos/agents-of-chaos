---
import Base from "../layouts/Base.astro";
import TeamGraph from "../components/TeamGraph.astro";
import TeamGrid from "../components/TeamGrid.astro";
---

<Base
  title="Team — Agents of Chaos"
  description="The people behind Agents of Chaos, and the work that proves them: the Agents of Chaos study, frontier-lab red-team campaigns, and the research world they come from."
>
  <div class="reading">
    <div class="page-head">
      <h1>Team</h1>
    </div>

    <p>
      We are researchers and red-teamers. Four of us are authors of
      <em>Agents of Chaos</em>
      (<a href="https://agentsofchaos.baulab.info/">Shapira et al., 2026</a>),
      the first study of emergent harm in populated multi-agent environments —
      covered by
      <a href="https://www.science.org/content/article/ai-algorithms-can-become-agents-chaos"><i>Science</i></a>
      and
      <a href="https://www.wired.com/story/openclaw-ai-agent-manipulation-security-northeastern-study/"><i>Wired</i></a>.
    </p>
  </div>

  <div class="reading">
    <span class="section-label"><span class="num">01</span>/ network</span>
  </div>
  <TeamGraph />

  <div class="reading">
    <span class="section-label"><span class="num">02</span>/ people</span>
  </div>
  <TeamGrid />
</Base>
