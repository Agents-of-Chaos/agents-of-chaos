  p { margin: 0 0 1rem; }
  .dek { font-size: 1.14rem; }
  figure { margin: 0; }
  figcaption { font-size: 0.92rem; color: var(--muted); max-width: 46rem; margin: 0.5rem auto 0; }
  svg { width: 100%; height: auto; display: block; font-family: inherit; }
  .tablewrap { overflow-x: auto; }
  table { border-collapse: collapse; width: 100%; font-size: 0.95rem; font-variant-numeric: tabular-nums; }
  th { font-variant: small-caps; letter-spacing: 0.06em; font-weight: 600; text-align: left; border-bottom: 1.5px solid var(--ink); padding: 0.35rem 0.9rem 0.35rem 0; vertical-align: bottom; }
  td { border-bottom: 1px solid var(--hair); padding: 0.42rem 0.9rem 0.42rem 0; vertical-align: top; }
  td.num, th.num { text-align: right; }
  tr.hi td { background: var(--wash); }
  .chip { display: inline-block; font-variant: small-caps; letter-spacing: 0.05em; font-size: 0.85rem; padding: 0.02rem 0.5rem; border-radius: 2px; white-space: nowrap; }
  .chip.a { background: #f7e6e2; color: var(--accent); }
  .chip.o { background: #e2edf0; color: var(--teal); }
  .chip.c { background: #edeadb; color: #5d5843; }
  .statrow { display: flex; gap: 2.4rem; flex-wrap: wrap; margin: 1.4rem 0 0.4rem; }
  .stat .v { font-size: 1.9rem; font-weight: 600; line-height: 1.1; font-variant-numeric: tabular-nums; }
  .stat .k { font-size: 0.88rem; color: var(--muted); max-width: 13rem; }
  .stat.a .v { color: var(--accent); } .stat.o .v { color: var(--teal); }
  .pull { border-top: 1px solid var(--hair); border-bottom: 1px solid var(--hair); padding: 0.9rem 0; margin: 1.8rem 0; font-size: 1.18rem; line-height: 1.4; }
  .src { color: var(--faint); font-size: 0.86rem; }
  footer.col { margin-top: 3.5rem; padding-top: 1rem; padding-bottom: 3rem; border-top: 1px solid var(--hair); font-size: 0.9rem; color: var(--muted); }
  a { color: inherit; }
  :focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  @media (prefers-reduced-motion: reduce) { * { transition: none !important; } }
</style>
