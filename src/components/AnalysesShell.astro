---
// /networks/analyses — twelve statistical readings of the AoC graphs.
// All prose is SERVER-rendered here from the baked envelopes (crawlable,
// no-JS readable); src/scripts/analyses/shell.ts only draws visualizations.
// The manifest import validates every envelope at build time — a bad bake
// fails the deploy, not the reader.
import { panels, sections, totalCount } from "../data/analyses-manifest";
import companiesData from "../data/companies.json";
import fundingData from "../data/funding.json";

const sectionLabel = new Map(sections.map((s) => [s.id, s.label]));

// node dossiers for hover tooltips: what the map's own tooltip knows about
// each node (name, vertical/kind, intensity, blurb), built from the LIVE
// graphs at build time — the client never bundles the full source JSONs.
// Compact keys: l=label g=group i=intensity b=blurb a=aliases.
type LooseNode = Record<string, unknown>;
const nodeInfo = {
  companies: Object.fromEntries(
    companiesData.companies.map((c) => [c.id, { l: c.name, g: c.vertical, i: c.intensity, b: c.blurb }]),
  ),
  funding: Object.fromEntries(
    (fundingData.nodes as LooseNode[]).map((n) => [
      n.id,
      {
        l: n.name,
        g: n.kind === "funder" ? ((n.funderKind as string) ?? "funder") : n.kind,
        ...(n.blurb || n.thesis ? { b: (n.blurb ?? n.thesis) as string } : {}),
        ...(Array.isArray(n.aliases) && n.aliases.length ? { a: n.aliases } : {}),
      },
    ]),
  ),
};
const nodeInfoJson = JSON.stringify(nodeInfo).replace(/</g, "\\u003c");
---

<div class="an-wrap">
  <aside class="an-nav" aria-label="analyses">
    {
      sections.map((s) => (
        <div class="an-nav-sec">
          <div class="an-nav-sec-label">{s.label}</div>
          {s.panels.map((p) => (
            <a class="an-nav-item" data-slug={p.env.slug} href={`?a=${p.env.slug}`} id={`an-${p.env.slug}`}>
              <span class="an-nav-idx">{p.index}</span>
              <span class="an-nav-text">
                <span class="an-nav-title">{p.env.title}</span>
                <span class="an-nav-sub">{p.env.sub}</span>
              </span>
            </a>
          ))}
        </div>
      ))
    }
    <div class="an-nav-foot">
      <a href="/networks">← the company map</a>
      <a href="/funding">← the funding map</a>
    </div>
  </aside>

  <main class="an-main">
    {
      panels.map((p) => (
        <section class="an-panel" data-slug={p.env.slug} data-stale-ids={JSON.stringify(p.staleIds)} hidden>
          <div class="an-kicker">
            {sectionLabel.get(p.env.graph)} · analysis {p.index} of {totalCount}
          </div>
          <h2 class="an-headline" set:html={p.env.headline} />
          {p.env.caveat && <p class="an-caveat">{p.env.caveat}</p>}
          <div class="an-intro" set:html={p.env.prose.intro} />
          {p.drift && (
            <p class="an-drift">
              computed from an earlier snapshot of the map — the graph has changed since; stale entries are marked †.
            </p>
          )}
          <div class="an-viz" data-viz>
            <noscript>
              <p class="graph-noscript">the picture needs JavaScript — the finding above doesn't.</p>
            </noscript>
          </div>
          <div class="an-how">
            <span class="an-how-label">how it works</span>
            <div set:html={p.env.prose.how} />
          </div>
          <details class="an-method">
            <summary>for the curious</summary>
            <div set:html={p.env.prose.method} />
          </details>
        </section>
      ))
    }
  </main>
</div>

<noscript>
  <style>
    .an-panel { display: block !important; }
    .an-panel[hidden] { display: block !important; }
  </style>
</noscript>

<script type="application/json" id="an-node-info" is:inline set:html={nodeInfoJson}></script>
<script>
  import { initAnalyses } from "../scripts/analyses/shell";
  initAnalyses();
</script>

<style is:global>
  /* ── /networks/analyses ─────────────────────────────────────────────────
     Runtime-created SVG/tables never get Astro's scoped hash → global, like
     the other graph pages. All classes an-* to stay decoupled. */
  .an-wrap {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 2.2rem;
    align-items: start;
    margin-top: 0.8rem;
  }
  .an-nav {
    position: sticky;
    top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    max-height: calc(100vh - 2rem);
    overflow-y: auto;
    padding-right: 0.4rem;
  }
  .an-nav-sec-label {
    font-variant: small-caps;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    color: var(--muted-2);
    margin-bottom: 0.3rem;
  }
  .an-nav-item {
    display: flex;
    gap: 0.55rem;
    padding: 0.32rem 0.5rem;
    border-left: 2px solid transparent;
    text-decoration: none;
    color: var(--fg);
    border-radius: 0 3px 3px 0;
  }
  .an-nav-item:hover { background: var(--accent-soft); }
  .an-nav-item.sel { border-left-color: var(--accent); background: var(--accent-soft); }
  .an-nav-idx {
    font-size: 0.72rem;
    color: var(--muted-2);
    min-width: 1.1em;
    text-align: right;
    padding-top: 2px;
  }
  .an-nav-title { display: block; font-size: 0.88rem; line-height: 1.25; }
  .an-nav-sub { display: block; font-size: 0.72rem; color: var(--muted-2); line-height: 1.3; }
  .an-nav-foot {
    margin-top: 0.4rem;
    padding-top: 0.7rem;
    border-top: 1px solid var(--rule-soft);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .an-nav-foot a { font-size: 0.78rem; color: var(--muted-2); text-decoration: none; }
  .an-nav-foot a:hover { color: var(--accent); }

  .an-main { min-width: 0; }
  .an-kicker {
    font-variant: small-caps;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    color: var(--muted-2);
  }
  .an-headline { font-size: 1.45rem; line-height: 1.3; margin: 0.35rem 0 0.6rem; font-weight: 400; }
  .an-headline strong { color: var(--accent); font-weight: 700; }
  .an-caveat {
    font-size: 0.82rem;
    color: var(--muted-2);
    border-left: 2px solid var(--accent);
    padding-left: 0.6rem;
    margin: 0.4rem 0 0.8rem;
  }
  .an-intro { max-width: 62ch; }
  .an-intro p { margin: 0.4rem 0; }
  .an-drift { font-size: 0.78rem; color: var(--muted-2); font-style: italic; }
  .an-viz { min-height: 240px; margin: 1.1rem 0; }
  .an-how {
    background: #f5f1e6;
    border-radius: 4px;
    padding: 0.8rem 1rem;
    max-width: 68ch;
    font-size: 0.9rem;
  }
  .an-how p { margin: 0.35rem 0; }
  .an-how-label {
    font-variant: small-caps;
    letter-spacing: 0.08em;
    font-size: 0.75rem;
    color: var(--muted-2);
    display: block;
    margin-bottom: 0.15rem;
  }
  .an-method { margin: 0.7rem 0 2rem; max-width: 68ch; font-size: 0.82rem; color: var(--muted-2); }
  .an-method summary { cursor: pointer; font-variant: small-caps; letter-spacing: 0.05em; }
  .an-method p { margin: 0.35rem 0; }

  /* blocks: flex-wrap composition inside .an-viz */
  .an-blocks { display: flex; flex-wrap: wrap; gap: 1.4rem 2rem; align-items: flex-start; }
  .an-block { min-width: 260px; }
  .an-block-title {
    font-variant: small-caps;
    letter-spacing: 0.06em;
    font-size: 0.8rem;
    color: var(--muted-2);
    margin-bottom: 0.35rem;
  }
  .an-empty { color: var(--muted-2); font-style: italic; font-size: 0.88rem; }

  /* node mentions in prose: hover shows the node's map-style dossier */
  .an-mention {
    border-bottom: 1px dotted var(--rule);
    cursor: help;
  }
  .an-mention:hover { color: var(--accent); border-bottom-color: var(--accent); }
  /* dossier tooltip internals (base .gtooltip + .t-name/.t-sub in global.css) */
  #an-tip .t-blurb { color: var(--fg); font-size: 0.74rem; margin-top: 3px; }
  #an-tip .t-int { letter-spacing: 1px; font-size: 0.64rem; }

  /* archetype: table */
  .an-table { border-collapse: collapse; font-size: 0.84rem; width: 100%; }
  .an-table th {
    text-align: left;
    font-weight: 400;
    font-variant: small-caps;
    letter-spacing: 0.05em;
    font-size: 0.76rem;
    color: var(--muted-2);
    border-bottom: 1px solid var(--rule-soft);
    padding: 2px 10px 4px 0;
  }
  .an-table td { padding: 3px 10px 3px 0; border-bottom: 1px solid #efe9dc; vertical-align: top; }
  .an-table .an-num { text-align: right; font-variant-numeric: tabular-nums; }
  .an-table .an-rank { color: var(--muted-2); font-size: 0.76rem; text-align: right; padding-right: 6px; }
  .an-table tr.an-lit td { background: var(--accent-soft); }
  .an-stale { opacity: 0.5; }
  .an-dagger { color: var(--muted-2); }
  .an-flag {
    font-size: 0.7rem;
    color: var(--muted-2);
    border: 1px solid var(--rule-soft);
    border-radius: 999px;
    padding: 0 6px;
    white-space: nowrap;
  }

  /* archetype: bars */
  .an-bars { display: flex; flex-direction: column; gap: 3px; font-size: 0.84rem; max-width: 560px; }
  .an-bar-row { display: grid; grid-template-columns: minmax(110px, 34%) 1fr 64px; gap: 8px; align-items: center; }
  .an-bar-row.an-lit .an-bar-label { color: var(--accent); }
  .an-bar-label { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .an-bar-track { background: #efe9dc; border-radius: 2px; height: 7px; position: relative; }
  .an-bar-fill { position: absolute; inset: 0 auto 0 0; background: #4c6b8a; border-radius: 2px; }
  .an-bar-val { font-size: 0.76rem; color: var(--muted-2); text-align: right; font-variant-numeric: tabular-nums; }

  /* archetype: matrix */
  .an-matrix-layers { display: flex; flex-wrap: wrap; gap: 1.4rem; }
  .an-matrix-grid { display: grid; gap: 2px; font-size: 0.72rem; }
  .an-matrix-col { writing-mode: vertical-rl; transform: rotate(180deg); color: var(--muted-2); padding: 2px 0; max-height: 90px; overflow: hidden; }
  .an-matrix-row { color: var(--muted-2); align-self: center; padding-right: 6px; white-space: nowrap; max-width: 130px; overflow: hidden; text-overflow: ellipsis; }
  .an-matrix-cell { aspect-ratio: 1; min-width: 16px; border-radius: 2px; }

  /* archetype: chain */
  .an-chains { display: flex; flex-direction: column; gap: 0.7rem; }
  .an-chain { display: flex; flex-wrap: wrap; align-items: center; gap: 6px; font-size: 0.84rem; }
  .an-pill {
    border: 1px solid var(--rule-soft);
    background: #fff;
    border-radius: 999px;
    padding: 2px 10px;
    white-space: nowrap;
  }
  .an-pill.an-lit { border-color: var(--accent); color: var(--accent); }
  .an-arrow { color: var(--muted-2); font-size: 0.76rem; white-space: nowrap; }
  .an-arrow i { font-style: normal; font-size: 0.68rem; letter-spacing: 0.03em; }
  .an-arrow-dashed { opacity: 0.6; }
  .an-arrow-dashed::after { content: " (unverified)"; font-size: 0.64rem; }

  /* svg text classes */
  .an-axis { font-size: 11px; fill: var(--muted-2); font-family: var(--font); }
  .an-label { font-size: 11.5px; fill: var(--fg); font-family: var(--font); paint-order: stroke; stroke: #fffff8; stroke-width: 2.5px; }
  .an-note { font-size: 10.5px; fill: var(--muted-2); font-family: var(--font); font-style: italic; }

  @media (max-width: 720px) {
    .an-wrap { grid-template-columns: 1fr; gap: 0.8rem; }
    .an-nav {
      position: static;
      max-height: none;
      flex-direction: row;
      overflow-x: auto;
      gap: 0.5rem;
      padding-bottom: 0.4rem;
      border-bottom: 1px solid var(--rule-soft);
    }
    .an-nav-sec { display: flex; gap: 0.4rem; }
    .an-nav-sec-label { display: none; }
    .an-nav-sub { display: none; }
    .an-nav-item { border-left: none; border-bottom: 2px solid transparent; white-space: nowrap; }
    .an-nav-item.sel { border-bottom-color: var(--accent); }
    .an-nav-foot { display: none; }
  }
</style>
