><div class="col-lg-6 site-footer__col-right"><ul class="site-footer__links list-reset"><!--[--><li><a class="tracking-footer-item link link--white" href="/privacy-policy" title="">Privacy Policy</a></li><li><a class="tracking-footer-item link link--white" href="/terms-and-conditions" title="">Terms and Conditions</a></li><li><a class="tracking-footer-item link link--white" href="/cookie-policy" title="">Cookie Policy</a></li><li><a class="tracking-footer-item link link--white" href="/accessibility-statement" title="">Accessibility Statement</a></li><li><a class="tracking-footer-item link link--white" href="/funding-opportunities/accessibility-support" title="">Accessibility Support</a></li><li><a class="tracking-footer-item link link--white" href="/social-media-policy" title="">Social Media Policy</a></li><li><a class="tracking-footer-item link link--white" href="https://aria.pinpointhq.com/" target="_blank" title="">Careers</a></li><li><a class="tracking-footer-item link link--white" href="/supply-to-us" title="">Supply to us</a></li><li><a class="tracking-footer-item link link--white" href="/about-aria/reporting-and-policies" title="">Reporting and Policies</a></li><!--]--></ul><div class="site-footer__text"><p>ARIA is a non-departmental public body, sponsored by the Department for Science, Innovation + Technology.</p></div></div></div></div></div></div></div><div class="site-footer__copyright"><div class="container"><div class="row"><div class="col-lg-1"></div><div class="col-lg-10 site-footer__copyright-content"><div class="site-footer__logo"><img src="/media/hsxblxrf/logo-aria-black.svg" alt="ARIA - Home"></div><span class="site">Copyright 2026</span></div></div></div></div></footer></div></div><!----><!--]--><!--teleport start--><!--teleport end--><!----><!--]--></div><div id="teleports"></div><script>window.__NUXT__={};window.__NUXT__.config={public:{BASE_URL:"",aos:{once:true}},app:{baseURL:"/",buildId:"1d8e0df2-027f-4e27-b658-2ab844ed7fa6",buildAssetsDir:"/_nuxt/",cdnURL:""}}</script><script type="application/json" data-nuxt-data="nuxt-app" data-ssr="true" id="__NUXT_DATA__">[["ShallowReactive",1],{"data":2,"state":278,"once":281,"_errors":282,"serverRendered":44,"path":45,"pinia":284,"connectionTestOne":-1,"connectionTestTwo":-1,"base_url":287},["ShallowReactive",3],{"$fNeBMliuQ3FucnyVWqzNhJrjsXjbu1B_f76YQvxuf3cI":4},{"opportunitySpacesMenu":5,"modules":47,"scriptsAtTop":93,"scriptsAtBottom":21,"id":94,"languageCode":95,"pageName":42,"scrollSmoothness":92,"gtmCode":21,"topNav":96,"footer":194,"seo":246,"sharing":250,"pageType":277},{"title":6,"subTitle":7,"exploreText":8,"image":9,"imageMobile":12,"backLink":14,"signUpLink":18,"items":22,"activeBackgroundColor":46},"Mathematics for Safe AI","Opportunity space","Explore this space",{"src":10,"alt":11},"/media/dmfcz4jf/mfsai.png?rmode=pad&format=webp&quality=100","Graphic of several clusters of geometric shapes with an orange and purple gradient making up the other half",{"src":13,"alt":11},"/media/apxh140v/mfsai_1.png?rmode=pad&format=webp&quality=100",{"isActive":15,"text":16,"href":17,"title":16},false,"Explore our Opportunity spaces","/opportunity-spaces",{"isActive":15,"text":19,"href":20,"title":21},"Sign up for updates","/sign-up-for-updates","",[23,27,32],{"title":24,"link":25},"Overview",{"isActive":15,"text":6,"href":26,"title":6},"/opportunity-spaces/mathematics-for-safe-ai",{"title":28,"link":29,"children":31},"Opportunity seeds",{"isActive":15,"text":28,"href":30,"title":28},"/opportunity-spaces/mathematics-for-safe-ai/opportunity-seeds",[],{"title":33,"link":34,"children":36},"Programme: Safeguarded AI",{"isActive":15,"text":33,"href":35,"title":33},"/opportunity-spaces/mathematics-for-safe-ai/safeguarded-ai",[37,41],{"title":38,"link":39},"Structure + funded projects",{"isActive":15,"text":38,"href":40,"title":38},"/opportunity-spaces/mathematics-for-safe-ai/safeguarded-ai/funded-projects",{"title":42,"link":43},"Funding",{"isActive":44,"text":42,"href":45,"title":42},true,"/opportunity-spaces/mathematics-for-safe-ai/safeguarded-ai/funding","#ccbbed",[48,63,66,89],{"type":49,"title":50,"text":51,"colour1":52,"colour2":53,"breadcrumb":54,"noBottomMargin":15,"hideGradient":15},"header","Safeguarded AI","Backed by £59m, Safeguarded AI sits within the Mathematics for Safe AI opportunity space and aims to demonstrate a world where we can use fleets of AI agents to model and verify critical cyber and cyber-physical systems, radically boosting societal resilience.","Orange","Purple",[55,58,60,61,62],{"isActive":15,"text":56,"href":57,"title":21},"Home","/home",{"isActive":15,"text":59,"href":17,"title":21},"Opportunity spaces",{"isActive":15,"text":6,"href":26,"title":21},{"isActive":15,"text":50,"href":35,"title":21},{"isActive":44,"text":42,"href":45,"title":21},{"type":64,"text":65,"mediumLayout":15,"fullWidth":15},"rich-text-content","\u003Cp>\u003Cspan class=\"h5\">Funding: Technical Area 2, Cybersecurity\u003C/span>\u003C/p>\n\u003Cp>\u003Cspan class=\"h7\">This funding call is now closed.\u003C/span>\u003C/p>\n\u003Cp>As part of our \u003Ca rel=\"noopener\" href=\"/media/ikrkutfk/safeguarded-ai-programme-thesis-v2.pdf\" target=\"_blank\" title=\"Safeguarded AI Programme Thesis V2\">updated programme thesis\u003C/a>, we seek to test and accelerate the hypothesis that AI-enabled formal methods can make high-assurance cyber defence practical at scale.\u003C/p>\n\u003Cp>Within Technical Area 2, this funding call pursues the question: given the advances in AI and formal methods, what are the most ambitious, security-critical systems we can verify today?\u003C/p>\n\u003Cp>We will fund teams to build production-grade, security-critical software components whose key security properties are backed by machine-checked proofs, validated through coordinated red-team exercises.\u003C/p>\n\u003Cp>We will evaluate teams for their credible interest and ability to carry developed capabilities towards large-scale deployment, whether themselves or through spinouts, partnerships, upstreaming, or other routes.\u003Cbr>\u003Cbr>\u003C/p>\n\u003Cp>\u003Cspan class=\"h5\">Two Tracks \u003C/span>\u003C/p>\n\u003Cp>The call is structured as two tracks: Track 1 (Blue Teams) for building and verifying security-critical components, and Track 2 (Red Team) for adversarial evaluation.\u003C/p>\n\u003Cp>\u003Cstrong>Track 1 | Blue Teams: \u003C/strong>We will fund 3–6 teams to build production-grade, security-critical software components whose key security properties are backed by machine-checked proofs, under clearly stated threat models and assumptions, using AI as a central means of reaching levels of ambition for formal proof that would otherwise not be tractable.\u003C/p>\n\u003Cp>\u003Cstrong>Track 2 | Red Team: \u003C/strong>We will fund one central Red Team. They will be responsible for executing, within each sprint cycle, a thorough pen-testing effort of every Blue Team’s system, and document the results in a report. Just like for Blue Teams, the intelligent use of AI will play a central role in thorough Red Teaming.\u003C/p>\n\u003Cp>Funding for the track 1 Blue Teams will be provided under our R&amp;D funding terms, while funding for the track 2 Red Team will be provided under our commercial service terms. Please read the \u003Ca rel=\"noopener\" href=\"/media/1padxpaf/safeguarded-ai_cybersecurity_solicitation.pdf\" target=\"_blank\" title=\"Safeguarded Ai Cybersecurity Solicitation [PDF]\">call for proposals\u003C/a> for details on each.\u003C/p>\n\u003Cp>\u003Cem>Note that Red and Blue Teams need to be independent. While applicants are free to apply to both tracks, we will not appoint the same organisation or team to serve in both capacities.\u003C/em>\u003Cbr>\u003Cbr>\u003C/p>\n\u003Cp>\u003Cspan class=\"h5\">Who should apply?\u003C/span>\u003C/p>\n\u003Cp>We sought applications from across the R&amp;D ecosystem, including startups, industry and academia. We typically require the majority of the project work to be conducted in the UK (i.e. &gt;50% of project costs and personnel time).\u003C/p>\n\u003Cp>\u003Cspan class=\"h7\">Join a team\u003C/span>\u003C/p>\n\u003Cp>We have a live teaming tool that allows applicants to find complementary expertise. After a quick registration, you can browse other researchers and request an introduction from the ARIA team to explore potential collaborations.\u003C/p>\n\u003Cp>\u003Cspan class=\"btn\">\u003Ca rel=\"noopener\" href=\"https://forms.monday.com/forms/6faba0cdd8d1ee6795f4fc71c4c72ca5?r=euc1\" target=\"_blank\" title=\"Sign up for teaming\" data-anchor=\"?r=euc1\">Register for teaming\u003C/a>\u003C/span>\u003C/p>\n\u003Cp>\u003Cbr>For more information read the \u003Ca rel=\"noopener\" href=\"/media/1padxpaf/safeguarded-ai_cybersecurity_solicitation.pdf\" target=\"_blank\" title=\"Safeguarded Ai Cybersecurity Solicitation [PDF]\">call for proposals\u003C/a>.\u003C/p>",{"type":67,"title":68,"columns":69},"download","Resources",[70],{"header":21,"links":71},[72,79,83,86],{"type":73,"text":74,"href":75,"fileExtension":76,"fileSize":77,"target":78},"file","Call for proposals [PDF - 1001.49Kb]","/media/1padxpaf/safeguarded-ai_cybersecurity_solicitation.pdf","PDF","1001.49Kb","_blank",{"type":73,"text":80,"href":81,"fileExtension":76,"fileSize":82,"target":78},"Call for proposals (accessible) [PDF - 757.93Kb]","/media/ififbryj/safeguarded-ai-cybersecurity-solicitation_accessible.pdf","757.93Kb",{"isActive":15,"text":84,"href":85,"title":21},"Accessibility support","/funding-opportunities/accessibility-support",{"isActive":15,"text":87,"href":88,"title":21},"Applicant guidance","/funding-opportunities/applicant-guidance",{"type":90,"cssSizeClass":91,"height":92},"spacer-comp","medium",0,"\u003C!-- Start cookieyes banner --> \n\u003Cscript id=\"cookieyes\" type=\"text/javascript\" src=\"https://cdn-cookieyes.com/client_data/eae9957b4a0acd8b0ca247e2/script.js\">\u003C/script> \n\u003C!-- End cookieyes banner -->\n\n\u003C!-- Google tag (gtag.js) -->\n\u003Cscript async src=\"https://www.googletagmanager.com/gtag/js?id=G-QB5LXNMKJN\">\u003C/script>\n\u003Cscript>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'G-QB5LXNMKJN');\n\u003C/script>\n\n\n\n\u003Cstyle>\n.biography-swiper,\n.team-cards {\n    margin-bottom: 60px;\n}\n.quick-link__label {\ndisplay: none;\n}\n.site-footer__logo img {\n filter: invert(1);\n}\n\n.rte-image-text {\n  display: flex;\n  align-items: flex-start;\n  gap: 80px;\n  max-width: 1000px;\n  margin: 0 auto 50px;\n}\n\n.rte-image-text__image {\n  flex: 0 0 300px;\n}\n\n.rte-image-text__text {\n  flex: 1;\n}\n\n@media (max-width: 800px) {\n  .rte-image-text {\n    flex-direction: column;\n    align-items: center;\n    gap: 20px;\n  }\n\n  .rte-image-text__image {\n    flex: 0 0 auto;\n        width: 100%;\n        height: auto;\n  }\n  .rte-image-text__image img {\n    height: auto;\n  }\n}\n\n.opportunity-space__feature__text p {\n    font-size: 1rem;\n}\n\n.creator-card-modal__modules .media-item { margin: 0; }\n\n@media (max-width: 46.24em) {\n    .standout-copy:not(.has-bg-colour) .container {\n        padding: 32px 0 !important;\n    }\n}\n\n@media (min-width: 46.25em) {\n    .accordion__header {\n        padding: 24px 34px 24px 0;\n    }\n}\n\nli.opportunity-space__menu-item[style*=\"--active-bg:#00b2a1;\"]\n.opportunity-space__menu-item--active-child {\n  background-color: #99E0D9 !important;\n}\n\n@media (max-width: 740px) {\n  .has-side-menu .cky-btn-revisit-wrapper {\n    bottom: 105px;\n  }\n}\n\n.error-nuxt-message { display: none };\n.debug-view { display: none };\n\n\u003C/style>\n\n\u003Cscript>\nwindow.setTimeout(() => {\n  window.dispatchEvent(new Event('resize'));\n}, 800);\n\nwindow.setTimeout(() => {\n  if (document.querySelector('.page-has-side-menu')) {\n    document.body.classList.add('has-side-menu');\n  }\n}, 200);\n\u003C/script>\n\n\u003C!--intercom-->\n\u003Cdiv data-intercom-id=\"i5uhzwkf\">\u003C/div>\n",2872,"en",{"logo":97,"nodes":100,"headerLinks":174,"menuLinks":179,"activeItem":186,"menuText":187,"menuTextClose":188,"search":189,"animationOffText":192,"animationOnText":193},{"text":98,"href":99},"ARIA - Home","/media/hsxblxrf/logo-aria-black.svg",[101,123,149,169],{"text":102,"href":103,"target":103,"id":103,"nodes":104,"noOpener":44,"noReferrer":15},"About us",null,[105,109,114,118],{"text":102,"href":106,"target":103,"id":107,"nodes":108,"noOpener":15,"noReferrer":15},"/about-aria","2207",[],{"text":110,"href":111,"target":103,"id":112,"nodes":113,"noOpener":15,"noReferrer":15},"Our team","/about-aria/our-team","2159",[],{"text":115,"href":116,"target":78,"id":103,"nodes":117,"noOpener":15,"noReferrer":15},"Work with us","https://aria.pinpointhq.com/",[],{"text":119,"href":120,"target":103,"id":121,"nodes":122,"noOpener":15,"noReferrer":15},"Reporting and policies","/about-aria/reporting-and-policies","2160",[],{"text":124,"href":103,"target":103,"id":103,"nodes":125,"noOpener":44,"noReferrer":15},"What we do",[126,131,134,139,144],{"text":127,"href":128,"target":103,"id":129,"nodes":130,"noOpener":15,"noReferrer":15},"How we work","/how-we-work","2817",[],{"text":59,"href":17,"target":103,"id":132,"nodes":133,"noOpener":15,"noReferrer":15},"2215",[],{"text":135,"href":136,"target":103,"id":137,"nodes":138,"noOpener":15,"noReferrer":15},"Activation Partners","/activation-partners","2174",[],{"text":140,"href":141,"target":103,"id":142,"nodes":143,"noOpener":15,"noReferrer":15},"Innovator Circles","/innovator-circles","3744",[],{"text":145,"href":146,"target":103,"id":147,"nodes":148,"noOpener":15,"noReferrer":15},"AI in Science","/ai-in-science","3785",[],{"text":42,"href":103,"target":103,"id":103,"nodes":150,"noOpener":44,"noReferrer":15},[151,156,159,164],{"text":152,"href":153,"target":103,"id":154,"nodes":155,"noOpener":15,"noReferrer":15},"Funding opportunities","/funding-opportunities