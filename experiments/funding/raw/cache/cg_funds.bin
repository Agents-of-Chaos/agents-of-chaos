  <body class="page">
    <a class="not-focus:sr-only absolute top-4 left-4 bg-black text-white
    fs-sans-md py-4 px-6 z-9999" href="#content">Skip to Content</a>

    <header
	class="site-header max-w-main mx-auto px-1 pt-1 lg:pt-2 lg:px-2 relative z-index-50" x-data="{
				menuOpen: false,
				init() {
					const mediaQuery = window.matchMedia('(min-width: 64rem)');
					mediaQuery.onchange = (e) => {
						$dispatch('resize');
						if (e.matches && this.menuOpen) {
							this.menuOpen = false;
						}
					};

					// Use RAF for performant scroll updates
					let ticking = false;
					window.addEventListener('scroll', () => {
						if (!ticking) {
							window.requestAnimationFrame(() => {
								document.documentElement.style.setProperty('--scroll-y', `${window.scrollY}px`);
								ticking = false;
							});
							ticking = true;
						}
					}, { passive: true });
				}
			}" x-init="init">


	<div class="
		  top-0 min-[600px]:top-[calc(var(--wp-admin-bar-height,0px))]
		  fixed h-[54px]
		  left-0 w-full z-40 lg:h-[68px]
		  bg-surface
		  bg-[image:var(--gradient)]
		  bg-[length:100%_50vh]
		  bg-no-repeat
		  pointer-events-none
		  [background-position-y:calc(-1*var(--scroll-y,0px))]"></div>

