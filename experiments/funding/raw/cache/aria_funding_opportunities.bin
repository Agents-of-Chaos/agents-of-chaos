ript><link rel="icon" type="image/x-icon" href="/favicon.ico"><link rel="icon" type="image/png" sizes="16x16" href="/nuxtassets/favicons/favicon-16x16.png"><link rel="icon" type="image/png" sizes="32x32" href="/nuxtassets/favicons/favicon-32x32.png"><link rel="apple-touch-icon" sizes="180x180" href="/nuxtassets/favicons/apple-touch-icon.png"><link rel="icon" type="image/png" sizes="192x192" href="/nuxtassets/favicons/android-chrome-192x192.png"><link rel="icon" type="image/png" sizes="512x512" href="/nuxtassets/favicons/android-chrome-512x512.png"><meta name="description" content="Discover our open funding calls, across programmes and opportunity seeds, and look back on past ones."><meta name="keywords" content="funding calls, opportunities, research grants, science technology agency, Research funding applications, Large-scale research funding, Individual research team funding, complex large-scale research ideas"><meta property="og:title" content="Funding opportunities"><meta property="og:description" content="Discover our open funding calls and look back on past ones."><meta property="og:image" content="https://aria.org.uk/media/ivop5iin/aria-web-card-9c.jpg?width=600&format=webp&quality=100&v=1db6698e4fe6120"><meta property="og:url" content="https://aria.org.uk/funding-opportunities"><meta name="twitter:card" content="summary_large_image"><meta name="twitter:site" content="@ARIA_research"><meta name="twitter:title" content="Funding opportunities"><meta name="twitter:description" content="Discover our open funding calls and look back on past ones."><meta name="twitter:image" content="https://aria.org.uk/media/ivop5iin/aria-web-card-9c.jpg?width=600&format=webp&quality=100&v=1db6698e4fe6120"><meta name="twitter:url" content="https://aria.org.uk/funding-opportunities"></head><body><!--teleport start anchor--><a href="#main-content" class="skip-link">Skip to main content</a><!--teleport anchor--><div id="__nuxt"><!--[--><!--[--><!--[--><!----><!----><!----><!----><!--